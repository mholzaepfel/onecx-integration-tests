{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneCX Integration Tests Platform Configuration",
  "description": "Configuration schema for OneCX platform integration tests",
  "type": "object",
  "properties": {
    "platformConfig": {
      "$ref": "#/definitions/platformConfig"
    }
  },
  "required": ["platformConfig"],
  "definitions": {
    "platformConfig": {
      "type": "object",
      "description": "Platform configuration settings",
      "properties": {
        "importData": {
          "type": "boolean",
          "description": "Whether to run data import after starting services",
          "default": true
        },
        "withLoggingEnabled": {
          "oneOf": [
            {
              "type": "boolean",
              "description": "Enable or disable all logging"
            },
            {
              "type": "array",
              "description": "Array of service names to enable logging for",
              "items": {
                "type": "string"
              }
            }
          ],
          "default": true
        },
        "heartbeat": {
          "$ref": "#/definitions/heartbeatConfig"
        },
        "platformOverrides": {
          "$ref": "#/definitions/platformOverrides"
        },
        "container": {
          "$ref": "#/definitions/containerConfig"
        },
        "config": {
          "type": "object",
          "description": "Additional configuration settings",
          "properties": {
            "importsPath": {
              "type": "string",
              "description": "Path to the directory containing import scripts and data"
            },
            "realm": {
              "type": "string",
              "description": "Realm name for Keycloak"
            },
            "realmPath": {
              "type": "string",
              "description": "Path to the Keycloak realm JSON file"
            }
          }
        }
      }
    },
    "heartbeatConfig": {
      "type": "object",
      "description": "Heartbeat monitoring configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable heartbeat monitoring"
        },
        "interval": {
          "type": "number",
          "description": "Heartbeat check interval in milliseconds",
          "default": 10000,
          "minimum": 1000
        },
        "failureThreshold": {
          "type": "number",
          "description": "Number of consecutive failures before logging error",
          "default": 3,
          "minimum": 1
        }
      },
      "required": ["enabled"]
    },
    "platformOverrides": {
      "type": "object",
      "description": "Image overrides for testing against different images",
      "properties": {
        "core": {
          "$ref": "#/definitions/coreOverrides"
        },
        "services": {
          "$ref": "#/definitions/servicesOverrides"
        },
        "bff": {
          "$ref": "#/definitions/bffOverrides"
        },
        "ui": {
          "$ref": "#/definitions/uiOverrides"
        }
      }
    },
    "containerConfig": {
      "type": "object",
      "description": "User-defined container configurations",
      "properties": {
        "service": {
          "type": "array",
          "description": "Array of service containers",
          "items": {
            "$ref": "#/definitions/svcContainer"
          }
        },
        "bff": {
          "type": "array",
          "description": "Array of BFF containers",
          "items": {
            "$ref": "#/definitions/bffContainer"
          }
        },
        "ui": {
          "type": "array",
          "description": "Array of UI containers",
          "items": {
            "$ref": "#/definitions/uiContainer"
          }
        },
        "e2e": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/e2eContainer"
          },
          "description": "E2E test container (e.g., Playwright)"
        }
      }
    },
    "imageOverride": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/definitions/dockerImage"
        }
      }
    },
    "coreOverrides": {
      "type": "object",
      "description": "Core service image overrides",
      "properties": {
        "postgres": {
          "$ref": "#/definitions/imageOverride"
        },
        "keycloak": {
          "$ref": "#/definitions/imageOverride"
        },
        "importmanager": {
          "$ref": "#/definitions/imageOverride"
        }
      }
    },
    "servicesOverrides": {
      "type": "object",
      "description": "Backend service image overrides",
      "properties": {
        "iamKc": {
          "$ref": "#/definitions/imageOverride"
        },
        "parameter": {
          "$ref": "#/definitions/imageOverride"
        },
        "workspace": {
          "$ref": "#/definitions/imageOverride"
        },
        "userProfile": {
          "$ref": "#/definitions/imageOverride"
        },
        "theme": {
          "$ref": "#/definitions/imageOverride"
        },
        "tenant": {
          "$ref": "#/definitions/imageOverride"
        },
        "productStore": {
          "$ref": "#/definitions/imageOverride"
        },
        "permission": {
          "$ref": "#/definitions/imageOverride"
        }
      },
      "additionalProperties": {
        "$ref": "#/definitions/imageOverride"
      }
    },
    "bffOverrides": {
      "type": "object",
      "description": "BFF service image overrides",
      "properties": {
        "parameter": {
          "$ref": "#/definitions/imageOverride"
        },
        "shell": {
          "$ref": "#/definitions/imageOverride"
        },
        "workspace": {
          "$ref": "#/definitions/imageOverride"
        }
      },
      "additionalProperties": {
        "$ref": "#/definitions/imageOverride"
      }
    },
    "uiOverrides": {
      "type": "object",
      "description": "UI service image overrides",
      "properties": {
        "shell": {
          "$ref": "#/definitions/imageOverride"
        },
        "workspace": {
          "$ref": "#/definitions/imageOverride"
        }
      },
      "additionalProperties": {
        "$ref": "#/definitions/imageOverride"
      }
    },
    "dockerImage": {
      "type": "string",
      "description": "Docker image"
    },
    "environmentVariables": {
      "type": "object",
      "description": "Environment variables",
      "additionalProperties": {
        "type": "string"
      }
    },
    "networkAlias": {
      "type": "string",
      "description": "Network alias for the container"
    },
    "baseContainer": {
      "type": "object",
      "description": "Base container configuration with common properties",
      "properties": {
        "image": {
          "$ref": "#/definitions/dockerImage"
        },
        "environments": {
          "$ref": "#/definitions/environmentVariables"
        },
        "networkAlias": {
          "$ref": "#/definitions/networkAlias"
        },
        "commandHealthCheck": {
          "$ref": "#/definitions/commandHealthCheck"
        },
        "healthChecks": {
          "type": "array",
          "description": "One-pass wait strategies evaluated at container startup (http and/or log based)",
          "items": {
            "$ref": "#/definitions/healthCheckStrategy"
          }
        }
      },
      "required": ["image", "networkAlias"]
    },
    "commandHealthCheck": {
      "type": "object",
      "description": "Docker-level command health check — maps to withHealthCheck() + Wait.forHealthCheck(). Only one allowed per container.",
      "properties": {
        "test": {
          "type": "array",
          "description": "Health check command, e.g. [\"CMD-SHELL\", \"curl -f http://localhost:8080/q/health\"]",
          "items": {
            "type": "string"
          }
        },
        "interval": {
          "type": "number",
          "description": "Interval between checks in milliseconds"
        },
        "timeout": {
          "type": "number",
          "description": "Timeout per check in milliseconds"
        },
        "retries": {
          "type": "number",
          "description": "Number of retries before marking unhealthy"
        }
      },
      "required": ["test"]
    },
    "healthCheckStrategy": {
      "description": "One-pass wait strategy evaluated at container startup",
      "oneOf": [
        {
          "$ref": "#/definitions/httpHealthCheck"
        },
        {
          "$ref": "#/definitions/logHealthCheck"
        }
      ]
    },
    "onePassHealthCheckBase": {
      "type": "object",
      "properties": {
        "startupTimeout": {
          "type": "number",
          "description": "Maximum time in milliseconds to wait for this strategy to pass during startup"
        }
      }
    },
    "httpHealthCheck": {
      "description": "HTTP-based wait strategy — maps to testcontainers Wait.forHttp(path, port)",
      "allOf": [
        {
          "$ref": "#/definitions/onePassHealthCheckBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "http",
              "description": "Discriminator for HTTP health check strategy"
            },
            "path": {
              "type": "string",
              "description": "Path to probe, e.g. \"/q/health\""
            },
            "port": {
              "type": "number",
              "description": "Container-internal port to probe"
            },
            "abortOnContainerExit": {
              "type": "boolean",
              "description": "Abort wait if container exits before the check passes"
            },
            "statusCode": {
              "type": "number",
              "description": "Expected HTTP status code"
            },
            "body": {
              "type": "string",
              "description": "Expected response body substring"
            },
            "tls": {
              "type": "boolean",
              "description": "Use TLS (HTTPS)"
            },
            "method": {
              "type": "string",
              "description": "HTTP method, defaults to GET"
            },
            "headers": {
              "type": "object",
              "description": "Additional request headers",
              "additionalProperties": {
                "type": "string"
              }
            },
            "username": {
              "type": "string",
              "description": "Basic auth username"
            },
            "password": {
              "type": "string",
              "description": "Basic auth password"
            }
          },
          "required": ["type", "path", "port"]
        }
      ]
    },
    "logHealthCheck": {
      "description": "Log-based wait strategy — maps to testcontainers Wait.forLogMessage(message, times)",
      "allOf": [
        {
          "$ref": "#/definitions/onePassHealthCheckBase"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "log",
              "description": "Discriminator for log health check strategy"
            },
            "messageOrRegex": {
              "type": "string",
              "description": "Log message string or regex pattern (as string) to wait for"
            },
            "numberOfEntries": {
              "type": "number",
              "description": "Number of times the message must appear before the strategy passes",
              "default": 1,
              "minimum": 1
            }
          },
          "required": ["type", "messageOrRegex"]
        }
      ]
    },
    "svcDetails": {
      "type": "object",
      "description": "Service container specific details",
      "properties": {
        "databaseUsername": {
          "type": "string",
          "description": "Database username"
        },
        "databasePassword": {
          "type": "string",
          "description": "Database password"
        }
      },
      "required": ["databaseUsername", "databasePassword"]
    },
    "bffDetails": {
      "type": "object",
      "description": "BFF container specific details",
      "properties": {
        "permissionsProductName": {
          "type": "string",
          "description": "Product name for permissions"
        }
      },
      "required": ["permissionsProductName"]
    },
    "uiDetails": {
      "type": "object",
      "description": "UI container specific details",
      "properties": {
        "appBaseHref": {
          "type": "string",
          "description": "Application base href"
        },
        "appId": {
          "type": "string",
          "description": "Application ID"
        },
        "productName": {
          "type": "string",
          "description": "Product name"
        }
      },
      "required": ["appBaseHref", "appId", "productName"]
    },
    "svcContainer": {
      "description": "Service container configuration",
      "allOf": [
        {
          "$ref": "#/definitions/baseContainer"
        },
        {
          "type": "object",
          "properties": {
            "svcDetails": {
              "$ref": "#/definitions/svcDetails"
            }
          },
          "required": ["svcDetails"]
        }
      ]
    },
    "bffContainer": {
      "description": "BFF container configuration",
      "allOf": [
        {
          "$ref": "#/definitions/baseContainer"
        },
        {
          "type": "object",
          "properties": {
            "bffDetails": {
              "$ref": "#/definitions/bffDetails"
            }
          },
          "required": ["bffDetails"]
        }
      ]
    },
    "uiContainer": {
      "description": "UI container configuration",
      "allOf": [
        {
          "$ref": "#/definitions/baseContainer"
        },
        {
          "type": "object",
          "properties": {
            "uiDetails": {
              "$ref": "#/definitions/uiDetails"
            }
          },
          "required": ["uiDetails"]
        }
      ]
    },
    "e2eContainer": {
      "type": "object",
      "description": "E2E test container configuration (e.g., Playwright)",
      "properties": {
        "image": {
          "$ref": "#/definitions/dockerImage"
        },
        "networkAlias": {
          "$ref": "#/definitions/networkAlias"
        },
        "baseUrl": {
          "type": "string",
          "description": "Base URL for E2E tests (e.g., http://onecx-shell:8080/<BASEHREF>/)."
        },
        "timeoutMs": {
          "type": "number",
          "minimum": 1000,
          "default": 600000,
          "description": "Maximum wait time in milliseconds for E2E one-shot startup/finish before failing."
        },
        "environments": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Additional environment variables passed to the E2E container."
        }
      },
      "required": ["image", "networkAlias"]
    }
  }
}
